# Labitat Environment Variables
# Copy this file to .env and fill in your values

# Required: 32+ character random string used for AES-256-GCM encryption and session signing
# Generate with: openssl rand -base64 32
SECRET_KEY=change_me_to_a_random_32_char_string_minimum

# SQLite database path (default: file:/data/labitat.db for Docker)
DATABASE_URL=file:./data/labitat.db

# Set to "production" when deploying
NODE_ENV=development

# Optional: override the default port (3000)
# PORT=3000

# Optional: cache directory for widget cache (default: /data/cache in Docker)
# CACHE_DIR=./data/cache
